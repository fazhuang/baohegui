  "fields": {
    "project_name": {
      "label": "项目名称",
      "type": "text",
      "placeholder": "如：XX市智慧校园设备采购项目",
      "required": true,
      "max_length": 200,
      "section": "basic",
      "compliance_rule_ids": ["R004"],
      "help_text": "填写项目全称，应与立项批复文件一致"
    },
    "document_number": {
      "label": "招标文件编号",
      "type": "text",
      "placeholder": "如：GSZC-2026-001",
      "required": true,
      "max_length": 100,
      "section": "basic",
      "compliance_rule_ids": [],
      "help_text": "采购代理机构编制的招标文件编号"
    },
    "owner": {
      "label": "采购人/招标人",
      "type": "text",
      "placeholder": "如：XX市教育局",
      "required": true,
      "max_length": 200,
      "section": "basic",
      "compliance_rule_ids": ["R005"],
      "help_text": "招标项目的采购人或招标单位全称"
    },
    "budget": {
      "label": "预算金额",
      "type": "text",
      "placeholder": "如：500万元",
      "required": true,
      "max_length": 100,
      "section": "basic",
      "compliance_rule_ids": ["R006", "R204"],
      "help_text": "填写项目预算金额，包含单位（万元/亿元）"
    },
    "procurement_method": {
      "label": "采购方式",
      "type": "select",
      "required": true,
      "section": "basic",
      "options_source": "procurement_methods",
      "compliance_rule_ids": [],
      "help_text": "依据政府采购法及相关规定选择采购方式"
    },
    "qualification_requirements": {
      "label": "投标人资格要求",
      "type": "textarea",
      "placeholder": "逐条列出投标人应具备的资质条件…",
      "required": true,
      "section": "qualification",
      "compliance_rule_ids": ["R001", "R101", "R102", "R104", "R109", "R110", "R111", "R112"],
      "help_text": "包括资质等级、业绩要求、注册地要求等，不得设置歧视性条款",
      "rows": 6
    },
    "bid_rejection_conditions": {
      "label": "废标条件/无效投标条款",
      "type": "textarea",
      "placeholder": "逐条列明废标情形…",
      "required": true,
      "section": "qualification",
      "compliance_rule_ids": ["R003", "R106", "R109", "R009", "R010", "R109_C"],
      "help_text": "明确列出导致投标无效的具体情形，不得设置非法定废标条件",
      "rows": 5
    },
    "technical_params": {
      "label": "技术参数与规格要求",
      "type": "textarea",
      "placeholder": "详细描述采购标的的技术参数、规格、性能要求…",
      "required": false,
      "section": "technical",
      "compliance_rule_ids": ["R007", "R105", "R107", "R108", "R111_B", "R012", "R203"],
      "help_text": "参数不得指向特定品牌或具有排他性，应设置不少于3个品牌可满足的参数要求",
      "rows": 8
    },
    "evaluation_method": {
      "label": "评标方法",
      "type": "select",
      "required": true,
      "section": "evaluation",
      "options_source": "evaluation_methods",
      "compliance_rule_ids": ["R002", "R201", "R206"],
      "help_text": "依法必须选择法定评标方法之一"
    },
    "scoring_criteria": {
      "label": "评分标准/分值分配",
      "type": "textarea",
      "placeholder": "详细说明各评分因素的权重分配与评分细则…",
      "required": false,
      "section": "evaluation",
      "compliance_rule_ids": ["R103", "R112_B", "R113", "R008", "R011", "R202", "R205"],
      "help_text": "评分标准应量化可验证，主观分值不得超过总分值的30%",
      "rows": 8
    }
  },
  "field_section_groups": {
    "basic": {"label": "基础信息", "order": 1, "fields": ["project_name", "document_number", "owner", "budget", "procurement_method"]},
    "qualification": {"label": "资格条件", "order": 2, "fields": ["qualification_requirements", "bid_rejection_conditions"]},
    "technical": {"label": "技术规格", "order": 3, "fields": ["technical_params"]},
    "evaluation": {"label": "评标标准", "order": 4, "fields": ["evaluation_method", "scoring_criteria"]}
  }
}
