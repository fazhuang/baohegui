# 环境变量（含密码/密钥，严禁提交）
.env
.env.*
!.env.prod.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node
node_modules/
dist/

# 数据库
*.sqlite3

