# ============================================================
# 包合规 (baohegui) - 生产环境变量模板
# 部署前复制为 .env 并填写真实值
#   cp .env.prod.example .env
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
POSTGRES_USER=baohegui
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=baohegui

# ── MinIO / 对象存储 ─────────────────────────────────────────
MINIO_ROOT_USER=baohegui
MINIO_ROOT_PASSWORD=change-me-in-production

# ── 后端应用 ────────────────────────────────────────────────
BHG_DATABASE_URL=postgresql://baohegui:change-me-in-production@db:5432/baohegui
BHG_MINIO_ENDPOINT=minio:9000
BHG_SECRET_KEY=change-me-in-production

# ── 大模型 API ─────────────────────────────────────────────
BHG_LLM_PROVIDER=openai_compatible
BHG_LLM_API_BASE=https://api.deepseek.com/v1
BHG_LLM_API_KEY=sk-placeholder
BHG_LLM_MODEL=deepseek-chat

# ── 可选配置（以下均设有默认值，可按需取消注释）────────────
# BHG_DEBUG=false
# BHG_LOG_LEVEL=info
# BHG_LLM_MAX_TOKENS=4096
# BHG_LLM_TEMPERATURE=0.1
# BHG_LLM_RETRY_COUNT=3
# BHG_LLM_RETRY_DELAY=2.0
# BHG_LLM_TOKEN_LIMIT_PER_CALL=6000
# BHG_LLM_COST_PER_1K_INPUT=0.001
# BHG_LLM_COST_PER_1K_OUTPUT=0.002
# BHG_LLM_MOCK_MODE=false

# ── CORS 来源（生产环境必填）───────────────────────────────
# BHG_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── 邮件服务 (Resend) ──────────────────────────────────────
# BHG_RESEND_API_KEY=re_xxxxxxxxxxxxx
# BHG_EMAIL_FROM_ADDRESS=noreply@yourdomain.com
