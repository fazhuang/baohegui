# ═══════════════════════════════════════════════════════════════
# 前端开发环境 — 支持热重载 (HMR)
# ═══════════════════════════════════════════════════════════════
FROM node:22-alpine

WORKDIR /app

COPY package.json .
RUN npm install

COPY . .

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
